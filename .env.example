# ============================================================================
# Data directory
# ============================================================================
# REQUIRED: Absolute path on the host (or on a mounted network share) to the
# directory that contains the KIAS DBF data. That folder must directly hold
# the Daten/, Update/, and Formulare/ subdirectories.
#
# Linux example:        KIAS_DATA_DIR=/srv/kias
# macOS example:        KIAS_DATA_DIR=/Users/me/Kias
# Windows example:      KIAS_DATA_DIR=C:/Users/me/Kias
# WSL2 path example:    KIAS_DATA_DIR=/mnt/c/Users/me/Kias
# SMB share (mounted):  KIAS_DATA_DIR=/mnt/kias-share
#
# (For a Windows SMB share, mount it on the host first with `net use` or
# /etc/fstab; then point KIAS_DATA_DIR at the mountpoint.)
KIAS_DATA_DIR=./data

# Port to expose the web UI on the host. Inside the container the server
# always listens on 5175.
HOST_PORT=5175

# Optional: container timezone (affects log timestamps and date display).
TZ=Europe/Berlin

# ============================================================================
# Car model photos (optional)
# ============================================================================

# Master switch for the photo / silhouette area on the Fahrzeuge cards.
# Off by default, cards show only the count, model name, and the "Generationen
# ansehen →" footer. Set to "true" to enable the image area.
#
# When enabled:
#   - If a matching photo exists in KIAS_CAR_IMAGES_DIR, it is shown.
#   - If not, a generic SVG silhouette of the body type is shown as a fallback.
KIAS_SHOW_CAR_IMAGES=false

# Directory on the host containing photos for the Fahrzeuge card view.
#
# Filename rule: <model-slug>.<png|jpg|jpeg|webp|svg|avif>
#   - lowercase, ASCII only
#   - spaces -> "-"
#   - special chars stripped (ä→a, ö→o, ü→u, ß→ss, "/", "." etc. → "-")
#
# Examples:
#   mondeo.png            transit-connect.png       mustang-mach-e.png
#   fiesta.png            transit-courier.png       focus-electric.png
#   c-max.png             transit-custom-phev.png   ford-gt.png
#   ka-plus.png           ford-gt.png               s-max.webp
#
# Use PNGs with transparent background for the best card look. If no file
# matches a given model line, the UI falls back to a generic SVG silhouette.
KIAS_CAR_IMAGES_DIR=./car-images

# ============================================================================
# Logging
# ============================================================================

# Directory on the host where rotated log files should be written.
# Must be writable by uid 1000 (the container's "node" user).
# Example:
#   mkdir -p ./logs && sudo chown 1000:1000 ./logs   # Linux
KIAS_LOG_DIR=./logs

# Minimum log level. One of: fatal, error, warn, info, debug, trace.
# - info  (default) logs every HTTP request + startup/reload events
# - debug additionally logs the search filters and resolved bulletin codes
# - warn  reduces noise to 4xx/5xx responses and operational issues
LOG_LEVEL=info

# Log rotation thresholds. A new file is started whenever EITHER condition
# is met (size OR frequency), so big traffic days don't blow up one file.
# IMPORTANT: docker-compose does NOT strip inline "#" comments from .env
# values, keep comments on their own lines, never on the value line.

# Max file size before rotation (e.g. 5m, 100m, 1k, 1024b).
LOG_MAX_SIZE=10m

# Rotation frequency: "daily", "hourly", or a number of milliseconds.
LOG_FREQUENCY=daily

# How many historic files to keep. Older ones are deleted automatically.
LOG_MAX_FILES=14

# Set to "false" to suppress stdout (and thus `docker logs`) once file
# logging is on. Default keeps both for easier debugging.
LOG_STDOUT=true
